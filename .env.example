# Firecrawl API key — used to scrape the Amazon product page (title, rating,
# features, star distribution). Get one at https://firecrawl.dev/app
FIRECRAWL_API_KEY=

# Apify token + actor — used to fetch Amazon customer reviews. Firecrawl can't
# get past Amazon's sign-in wall on /product-reviews/, so we delegate reviews
# to an Apify actor that specializes in it.
#   1. Sign up at https://apify.com (free, $5 starter credit)
#   2. Get a token at https://console.apify.com/settings/integrations
#   3. Pick an Amazon-reviews actor at https://apify.com/store?search=amazon%20reviews
#      Paste its id (e.g. 'username/amazon-reviews-scraper') below.
APIFY_TOKEN=
APIFY_AMAZON_REVIEWS_ACTOR=

# AI Gateway key for the classifier. Vercel AI SDK uses this automatically
# when running on Vercel; for local development, paste a key from
# https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=
